---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title="Blog">
  <Header />
  <main class="px-6 py-24">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-3xl font-bold text-text">Blog</h1>
      <p class="mt-2 text-text-muted">Thoughts on code, tech, and life.</p>
      <div class="mt-10 space-y-4">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group block rounded-xl border border-border p-5 transition-all hover:border-accent/40 hover:shadow-md hover:shadow-accent/5"
          >
            <div class="flex items-baseline justify-between gap-4">
              <h2 class="font-semibold text-text transition-colors group-hover:text-accent">
                {post.data.title}
              </h2>
              <time class="shrink-0 text-xs text-text-muted">
                {formatDate(post.data.date)}
              </time>
            </div>
            <p class="mt-2 text-sm text-text-muted">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1.5">
                {post.data.tags.map((tag) => (
                  <span class="rounded-md bg-accent-subtle px-2 py-0.5 text-xs font-medium text-accent">
                    #{tag}
                  </span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
