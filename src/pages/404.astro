---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404">
  <Header />
  <main class="px-6 py-24">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-6xl font-bold text-text">404</h1>
      <p class="mt-4 text-text-muted">This page doesn't exist.</p>
      <a
        href="/"
        class="mt-8 inline-block text-sm text-text-muted transition-colors hover:text-text"
      >
        &larr; Go home
      </a>
    </div>
  </main>
  <Footer />
</Layout>
