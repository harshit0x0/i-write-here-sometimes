---
import { site } from '../data/site';
---

<section class="relative overflow-hidden px-6 py-28 sm:py-32">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(45%_40%_at_50%_60%,var(--accent-subtle),transparent)]"></div>
  <div class="mx-auto max-w-2xl">
    <div class="flex items-center gap-6 sm:gap-8">
      <img
        src="/images/code_pfp.jpeg"
        alt={site.name}
        class="h-20 w-20 rounded-full border-2 border-accent/20 object-cover shadow-lg sm:h-24 sm:w-24"
      />
      <div>
        <h1 class="animate-fade-in text-4xl font-bold tracking-tight text-text sm:text-5xl">
          {site.name}
        </h1>
        <p class="animate-fade-in-delay mt-2 text-lg text-accent sm:text-xl">
          {site.tagline}
        </p>
      </div>
    </div>
    <div class="animate-fade-in-delay-2 mt-8 flex flex-wrap gap-3">
      {site.social.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border border-border bg-bg-secondary px-3 py-1.5 text-sm text-text-muted transition-all hover:border-accent/40 hover:text-accent hover:shadow-sm"
        >
          {link.name}
        </a>
      ))}
    </div>
  </div>
</section>
