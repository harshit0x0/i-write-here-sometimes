---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<section class="border-t border-border px-6 py-24">
  <div class="mx-auto max-w-2xl">
    <h2 class="text-2xl font-semibold text-text">Blog</h2>
    <div class="mt-8 space-y-6">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="group block rounded-lg border border-border p-4 transition-colors hover:border-accent"
        >
          <div class="flex items-baseline justify-between gap-4">
            <h3 class="font-medium text-text transition-colors group-hover:text-accent">
              {post.data.title}
            </h3>
            <time class="shrink-0 text-sm text-text-muted">
              {formatDate(post.data.date)}
            </time>
          </div>
          <p class="mt-2 text-sm text-text-muted">{post.data.description}</p>
        </a>
      ))}
    </div>
    {posts.length > 0 && (
      <div class="mt-8">
        <a
          href="/blog"
          class="text-sm text-text-muted transition-colors hover:text-text"
        >
          View all posts &rarr;
        </a>
      </div>
    )}
  </div>
</section>
