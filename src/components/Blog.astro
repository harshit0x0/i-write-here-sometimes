---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<section class="border-t border-border px-6 py-24">
  <div class="mx-auto max-w-2xl">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">Blog</h2>
    <div class="mt-8 space-y-4">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="group block rounded-xl border border-border p-5 transition-all hover:border-accent/40 hover:shadow-md hover:shadow-accent/5"
        >
          <div class="flex items-baseline justify-between gap-4">
            <h3 class="font-semibold text-text transition-colors group-hover:text-accent">
              {post.data.title}
            </h3>
            <time class="shrink-0 text-xs text-text-muted">
              {formatDate(post.data.date)}
            </time>
          </div>
          <p class="mt-2 text-sm text-text-muted">{post.data.description}</p>
        </a>
      ))}
    </div>
    {posts.length > 0 && (
      <div class="mt-8">
        <a
          href="/blog"
          class="inline-flex items-center gap-1 text-sm font-medium text-accent transition-colors hover:text-accent-light"
        >
          View all posts
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
