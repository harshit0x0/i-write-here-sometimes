---
import { site } from '../data/site';
---

<section class="border-t border-border px-6 py-24">
  <div class="mx-auto max-w-2xl">
    <h2 class="text-2xl font-semibold text-text">Contact</h2>
    <p class="mt-4 text-text-muted">
      Feel free to reach out. I'm always open to new opportunities and interesting conversations.
    </p>
    <div class="mt-6">
      <a
        href={`mailto:${site.author.email}`}
        class="inline-flex items-center gap-2 text-text transition-colors hover:text-accent"
      >
        {site.author.email}
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
    <div class="mt-4 flex flex-wrap gap-4">
      {site.social.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-text-muted transition-colors hover:text-text"
        >
          {link.name}
        </a>
      ))}
    </div>
  </div>
</section>
