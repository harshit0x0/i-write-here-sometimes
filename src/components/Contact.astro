---
import { site } from '../data/site';
---

<section class="border-t border-border px-6 py-24">
  <div class="mx-auto max-w-2xl">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">Contact</h2>
    <p class="mt-4 text-text-muted">
      Feel free to reach out. I'm always open to new opportunities and interesting conversations.
    </p>
    <div class="mt-8">
      <a
        href={`mailto:${site.author.email}`}
        class="group inline-flex items-center gap-2 rounded-lg border border-border bg-bg-secondary px-4 py-2.5 text-sm font-medium text-text transition-all hover:border-accent/40 hover:bg-accent-subtle hover:text-accent hover:shadow-sm"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        {site.author.email}
      </a>
    </div>
    <div class="mt-6 flex flex-wrap gap-3">
      {site.social.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border border-border px-3 py-1.5 text-sm text-text-muted transition-all hover:border-accent/40 hover:text-accent hover:shadow-sm"
        >
          {link.name}
        </a>
      ))}
    </div>
  </div>
</section>
