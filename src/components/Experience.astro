---
const experiences = [
  {
    role: "Backend Developer",
    company: "Amrutam",
    period: "Jan 2025 - Present",
    description: "Building and maintaining backend services for the platform.",
    highlights: [
      "Built and maintained RESTful APIs with Node.js and TypeScript",
      "Integrated push notifications via Firebase Admin SDK",
      "Implemented image compression across the database using Azure Functions",
      "Built analytics reports with MongoDB aggregation pipelines",
    ],
  },
  {
    role: "Freelance Software Developer",
    company: "Self-employed",
    period: "Jan 2024 - Dec 2024",
    description: "Full-stack development for clients and personal projects.",
    highlights: [
      "Led end-to-end development of a responsive website for Manroland Sheetfed India using Next.js and TypeScript",
      "Developed full-stack applications including PUTA Election App and My One Mile",
    ],
  },
];
---

<section class="border-t border-border px-6 py-24">
  <div class="mx-auto max-w-2xl">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">Experience</h2>
    <div class="mt-8 space-y-0">
      {experiences.map((exp, i) => (
        <div class={`relative flex gap-6 ${i < experiences.length - 1 ? 'pb-8' : ''}`}>
          <div class="flex flex-col items-center">
            <div class="h-3 w-3 rounded-full border-2 border-accent bg-bg"></div>
            {i < experiences.length - 1 && (
              <div class="mt-1 w-px flex-1 bg-border"></div>
            )}
          </div>
          <div class="-mt-1 flex-1">
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <h3 class="font-semibold text-text">{exp.role}</h3>
              <span class="text-xs font-medium text-accent">{exp.period}</span>
            </div>
            <p class="mt-0.5 text-sm text-text-muted">{exp.company}</p>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">{exp.description}</p>
            {exp.highlights && (
              <ul class="mt-2 list-disc space-y-1 pl-4 text-sm text-text-muted">
                {exp.highlights.map((h) => <li>{h}</li>)}
              </ul>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
