---
import { site } from '../data/site';
---

<header class="sticky top-0 z-50 border-b border-border bg-bg/80 backdrop-blur-xl supports-[backdrop-filter]:bg-bg/60">
  <nav class="mx-auto flex max-w-2xl items-center justify-between px-6 py-4">
    <a href="/" class="text-lg font-bold tracking-tight text-text transition-colors hover:text-accent">
      {site.name}
    </a>
    <ul class="flex items-center gap-1">
      {site.nav.map((item) => (
        <li>
          <a
            href={item.url}
            class="rounded-lg px-3 py-1.5 text-sm text-text-muted transition-colors hover:bg-accent-subtle hover:text-accent"
          >
            {item.name}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
