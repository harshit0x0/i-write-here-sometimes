---
const skillGroups = [
  {
    category: "Languages",
    skills: ["TypeScript", "JavaScript", "C/C++"],
  },
  {
    category: "Frontend",
    skills: ["React", "Astro", "Tailwind CSS", "Next.js"],
  },
  {
    category: "Backend",
    skills: ["Node.js", "Express.js", "PostgreSQL", "MySQL", "MongoDB", "Azure SQL", "AWS"],
  },
  {
    category: "Tools",
    skills: ["Git", "GitHub", "Postman", "VS Code", "Visual Studio", "Figma", "Canva"],
  },
];
---

<section class="border-t border-border px-6 py-24">
  <div class="mx-auto max-w-2xl">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">Skills</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      {skillGroups.map((group) => (
        <div class="rounded-xl border border-border bg-bg-secondary/50 p-4">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-text-muted">{group.category}</h3>
          <div class="mt-3 flex flex-wrap gap-1.5">
            {group.skills.map((skill) => (
              <span class="rounded-md bg-accent-subtle px-2 py-1 text-xs font-medium text-accent">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
